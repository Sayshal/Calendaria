<div class="note-row{{#if selected}} selected{{/if}}" data-note-id="{{id}}" data-preset="{{presetId}}"
  data-visibility="{{visibility}}" data-display-style="{{displayStyle}}" style="--note-color: {{color}}">
  {{#if selectionMode}}
    <input type="checkbox" class="note-select-checkbox" {{#if selected}}checked{{/if}} />
  {{/if}}
  <div class="note-color" style="background-color: {{color}};"></div>
  <i class="{{icon}} note-icon"></i>
  <div class="note-info">
    <span class="note-name">{{name}}</span>
    <span class="note-date">{{dateLabel}}</span>
  </div>
  <span class="note-tags">
    {{#each presetBadges}}
      <i class="{{this.icon}} tag-preset" style="color: {{this.color}};" data-tooltip="{{this.label}}"></i>
    {{/each}}
    {{#if isHidden}}
      <i class="fas fa-eye-slash tag-visibility" data-tooltip="{{localize 'CALENDARIA.Common.Hidden'}}"></i>
    {{else if isSecret}}
      <i class="fas fa-eye-low-vision tag-visibility"
        data-tooltip="{{localize 'CALENDARIA.Note.Visibility.Secret'}}"></i>
    {{/if}}
    {{#if hasDuration}}
      <i class="fas fa-arrows-left-right tag-duration"
        data-tooltip="{{localize 'CALENDARIA.Common.HasDuration'}}"></i>
    {{/if}}
    {{#if isRecurring}}
      <i class="fas fa-rotate tag-recurrence"
        data-tooltip="{{localize 'CALENDARIA.NoteViewer.Filter.IsRecurring'}}"></i>
    {{/if}}
    {{#if isFestival}}
      <i class="fas fa-star tag-festival" data-tooltip="{{localize 'CALENDARIA.NoteViewer.Filter.IsFestival'}}"></i>
    {{/if}}
  </span>
</div>
