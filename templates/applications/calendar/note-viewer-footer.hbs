<div class="note-viewer-footer">
  <span class="note-count" data-tooltip="{{countTooltip}}" data-tooltip-direction="UP">
    {{#if totalNotes}}
      {{localize "CALENDARIA.NoteViewer.ShowingCount" shown=shownCount total=totalNotes}}
    {{else}}
      {{localize "CALENDARIA.NoteViewer.NoNotes"}}
    {{/if}}
  </span>
  {{#if isGM}}
    <div class="bulk-controls">
      {{#if selectionMode}}
        <input type="checkbox" class="select-all-checkbox" data-tooltip="{{localize 'CALENDARIA.NoteViewer.SelectAll'}}"
          data-tooltip-direction="UP" />
        <span class="selection-count">{{selectedCount}}</span>
        <div class="bulk-actions">
          <button type="button" class="bulk-btn" data-action="bulkAction" data-bulk="delete"
            data-tooltip="{{localize 'CALENDARIA.NoteViewer.BulkAction.Delete'}}" data-tooltip-direction="UP"
            {{#unless selectedCount}}disabled{{/unless}}>
            <i class="fas fa-trash"></i>
          </button>
          <button type="button" class="bulk-btn" data-action="bulkAction" data-bulk="preset"
            data-tooltip="{{localize 'CALENDARIA.NoteViewer.BulkAction.ChangePreset'}}" data-tooltip-direction="UP"
            {{#unless selectedCount}}disabled{{/unless}}>
            <i class="fas fa-tag"></i>
          </button>
          <button type="button" class="bulk-btn" data-action="bulkAction" data-bulk="visibility"
            data-tooltip="{{localize 'CALENDARIA.NoteViewer.BulkAction.ChangeVisibility'}}" data-tooltip-direction="UP"
            {{#unless selectedCount}}disabled{{/unless}}>
            <i class="fas fa-eye"></i>
          </button>
          <button type="button" class="bulk-btn" data-action="bulkAction" data-bulk="displayStyle"
            data-tooltip="{{localize 'CALENDARIA.NoteViewer.BulkAction.ChangeDisplayStyle'}}"
            data-tooltip-direction="UP" {{#unless selectedCount}}disabled{{/unless}}>
            <i class="fas fa-palette"></i>
          </button>
        </div>
      {{/if}}
      <button type="button" class="selection-toggle" data-action="toggleSelectionMode"
        data-tooltip="{{#if selectionMode}}{{localize 'CALENDARIA.NoteViewer.ExitSelection'}}{{else}}{{localize 'CALENDARIA.NoteViewer.Select'}}{{/if}}"
        data-tooltip-direction="UP">
        <i class="fas fa-{{#if selectionMode}}times{{else}}check-square{{/if}}"></i>
      </button>
    </div>
  {{/if}}
</div>
