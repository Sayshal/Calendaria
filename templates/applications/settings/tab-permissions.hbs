<section class="tab {{tab.cssClass}}" data-tab="{{tab.id}}" data-group="{{tab.group}}">

  <fieldset data-section="permissions">
    <legend>
      {{localize "CALENDARIA.SettingsPanel.Tab.Permissions"}}
      <button type="button" class="reset-section" data-action="resetSection" data-section="permissions" data-tooltip
        aria-label="{{localize "CALENDARIA.SettingsPanel.ResetSection.Tooltip"}}"><i class="fas fa-undo"></i></button>
    </legend>
    <p class="hint section-hint">{{localize "CALENDARIA.SettingsPanel.Permissions.Note"}}</p>

    <div class="permissions-table">
      <header class="permissions-header">
        <span>{{localize "PERMISSION.Permission"}}</span>
        <span>{{localize "USER.RolePlayer"}}</span>
        <span>{{localize "USER.RoleTrusted"}}</span>
        <span>{{localize "USER.RoleAssistant"}}</span>
      </header>

      <ul class="permissions-list">
        <li class="permission-row">
          <label class="permission-name">{{localize "CALENDARIA.Permissions.ViewHUD"}}</label>
          <input type="checkbox" name="permissions.viewHUD.player" data-tooltip
            aria-label="{{localize 'USER.RolePlayer'}}" {{#if permissions.viewHUD.player}}checked{{/if}} />
          <input type="checkbox" name="permissions.viewHUD.trusted" data-tooltip
            aria-label="{{localize 'USER.RoleTrusted'}}" {{#if permissions.viewHUD.trusted}}checked{{/if}} />
          <input type="checkbox" name="permissions.viewHUD.assistant" data-tooltip
            aria-label="{{localize 'USER.RoleAssistant'}}" {{#if permissions.viewHUD.assistant}}checked{{/if}} />
          <p class="hint">{{localize "CALENDARIA.Permissions.ViewHUDHint"}}</p>
